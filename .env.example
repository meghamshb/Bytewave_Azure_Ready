# Byte Wave — environment variables
# Copy this file to .env and fill in your values.

# Anthropic API key (required — powers Claude for AI feedback, questions, and chat)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# JWT secret for auth tokens (optional — a random secret is generated at startup if unset,
# but tokens won't survive server restarts; set a fixed value for production)
# JWT_SECRET=

# Optional: admin key for protected endpoints (e.g. /api/admin/prerender-clips)
# ADMIN_KEY=

# Optional: allowed CORS origins (comma-separated; defaults to localhost)
# CORS_ORIGINS=https://yourdomain.com

# Optional: PostHog analytics (frontend reads this via VITE_ prefix)
# VITE_POSTHOG_KEY=
